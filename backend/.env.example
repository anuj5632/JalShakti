# AquaGuard Backend Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# APP SETTINGS
# ===========================================
APP_NAME=AquaGuard API
DEBUG=true

# ===========================================
# MQTT SETTINGS (HiveMQ Cloud)
# ===========================================
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=aquaguard

# ===========================================
# FIREBASE SETTINGS
# ===========================================
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Your Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ===========================================
# GOOGLE OAUTH SETTINGS
# ===========================================
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# JWT SETTINGS
# ===========================================
# Generate a secure random string for production
JWT_SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===========================================
# SMS ALERT SETTINGS
# ===========================================

# Twilio (International)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Fast2SMS (India - Alternative)
FAST2SMS_API_KEY=

# ===========================================
# WATER QUALITY THRESHOLDS
# ===========================================
PH_MIN=6.5
PH_MAX=8.5
TDS_MAX=500
TURBIDITY_MAX=5
FLOW_MIN=0.5
WATER_LEVEL_MIN=10

# ===========================================
# ML MODEL SETTINGS
# ===========================================
MODEL_PATH=models/anomaly_detector.joblib
ANOMALY_THRESHOLD=-0.5
